// ── Portal system + Mill House equipment (init.sql) ───────

enum UserRole {
  admin
  employee
}

model users {
  id             Int       @id @default(autoincrement())
  name           String    @db.VarChar(200)
  email          String    @unique(map: "email") @db.VarChar(200)
  password       String?   @db.VarChar(200)
  role           UserRole  @default(employee)
  is_active      Boolean   @default(true)
  auth_provider  String    @default("local") @db.VarChar(20)
  mail_sent      Boolean   @default(false)
  microsoft_id   String?   @db.VarChar(200)
  created_at     DateTime? @default(now()) @db.Timestamp(0)
  updated_at     DateTime? @default(now()) @updatedAt @db.Timestamp(0)
  mappings       mappings[]

  @@map("users")
}

model apps {
  id          Int         @id @default(autoincrement())
  name        String      @unique(map: "name") @db.VarChar(200)
  description String?     @db.VarChar(500)
  icon        String?     @db.VarChar(100)
  color       String?     @db.VarChar(20)
  sort_order  Int         @default(0)
  is_active   Boolean     @default(true)
  created_at  DateTime?   @default(now()) @db.Timestamp(0)
  forms       forms[]
  mappings    mappings[]

  @@map("apps")
}

model forms {
  id            Int             @id @default(autoincrement())
  name          String          @db.VarChar(200)
  description   String?         @db.VarChar(500)
  form_key      String          @unique(map: "form_key") @db.VarChar(100)
  app_id        Int
  sort_order    Int             @default(0)
  is_active     Boolean         @default(true)
  created_at    DateTime?       @default(now()) @db.Timestamp(0)
  apps          apps            @relation(fields: [app_id], references: [id], onDelete: Cascade, map: "forms_ibfk_1")
  mapping_forms mapping_forms[]

  @@index([app_id], map: "app_id")
  @@map("forms")
}

model mappings {
  id             Int             @id @default(autoincrement())
  user_id        Int
  app_id         Int
  created_at     DateTime?       @default(now()) @db.Timestamp(0)
  users          users           @relation(fields: [user_id], references: [id], onDelete: Cascade, map: "mappings_ibfk_1")
  apps           apps            @relation(fields: [app_id], references: [id], onDelete: Cascade, map: "mappings_ibfk_2")
  mapping_forms  mapping_forms[]

  @@unique([user_id, app_id], map: "uq_user_app")
  @@map("mappings")
}

model mapping_forms {
  mapping_id Int
  form_id    Int
  mappings   mappings @relation(fields: [mapping_id], references: [id], onDelete: Cascade, map: "mapping_forms_ibfk_1")
  forms      forms    @relation(fields: [form_id], references: [id], onDelete: Cascade, map: "mapping_forms_ibfk_2")

  @@id([mapping_id, form_id])
  @@map("mapping_forms")
}

model mh_equipment {
  id             Int                @id @default(autoincrement())
  equip_no       String             @db.VarChar(30)
  plant          String             @default("Mill House") @db.VarChar(50)
  name           String             @db.VarChar(200)
  location       String?            @db.VarChar(200)
  commissioned   String?            @db.VarChar(50)
  drive          String?            @db.VarChar(300)
  photo          String?            @db.MediumText
  plate          String?            @db.MediumText
  sort_order     Int                @default(0)
  created_at     DateTime?          @default(now()) @db.Timestamp(0)
  updated_at     DateTime?          @default(now()) @updatedAt @db.Timestamp(0)
  mh_specs       mh_specs[]
  mh_oem_schedule mh_oem_schedule[]
  mh_history     mh_history[]

  @@map("mh_equipment")
}

model mh_specs {
  id         Int           @id @default(autoincrement())
  equip_id   Int
  lbl        String        @db.VarChar(300)
  val        String?       @db.Text
  sort_order Int           @default(0)
  equipment  mh_equipment  @relation(fields: [equip_id], references: [id], onDelete: Cascade)

  @@map("mh_specs")
}

model mh_oem_schedule {
  id       Int           @id @default(autoincrement())
  equip_id Int
  no       Int
  comp     String?       @db.VarChar(500)
  act      String?       @db.Text
  iv_W     String?       @db.Char(1)
  iv_M     String?       @db.Char(1)
  iv_Q     String?       @db.Char(1)
  iv_H     String?       @db.Char(1)
  iv_Y     String?       @db.Char(1)
  iv_T     String?       @db.Char(1)
  equipment mh_equipment @relation(fields: [equip_id], references: [id], onDelete: Cascade)

  @@map("mh_oem_schedule")
}

model mh_history {
  id          Int           @id @default(autoincrement())
  equip_id    Int
  season      String?       @db.VarChar(20)
  year        String?       @db.VarChar(64)
  date_start  DateTime?     @db.Date
  date_finish DateTime?     @db.Date
  obs         String?       @db.Text
  act         String?       @db.Text
  cost        String?       @db.VarChar(50)
  svc         String?       @db.VarChar(20)
  provider    String?       @db.VarChar(300)
  resp        String?       @db.VarChar(300)
  rem         String?       @db.Text
  created_at  DateTime?     @default(now()) @db.Timestamp(0)
  updated_at  DateTime?     @default(now()) @updatedAt @db.Timestamp(0)
  equipment   mh_equipment  @relation(fields: [equip_id], references: [id], onDelete: Cascade)

  @@map("mh_history")
}

# ─── Server ───────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ──────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/gsma_portal

# ─── MySQL / Prisma ───────────────────────────────────────
DATABASE_URL="mysql://root:yourpassword@localhost:3306/gsma_forms"

# ─── MySQL (temp / dev) ───────────────────────────────────
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=yourpassword
MYSQL_DATABASE=gsma_forms

# ─── JWT ──────────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# ─── Microsoft Azure AD (Outlook login) ───────────────────
AZURE_TENANT_ID=your_tenant_id
AZURE_CLIENT_ID=your_client_id
AZURE_CLIENT_SECRET=your_client_secret

# ─── Nodemailer (SMTP – use Outlook or Gmail) ─────────────
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=your_email@company.com
SMTP_PASS=your_smtp_password
SMTP_FROM="DigiLog <your_email@company.com>"

# ─── Frontend (Vite env vars – copy to frontend/.env) ─────
VITE_API_URL=http://localhost:5000/api
VITE_AZURE_CLIENT_ID=your_client_id
VITE_AZURE_TENANT_ID=your_tenant_id
VITE_REDIRECT_URI=http://localhost:5173
